{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["message", "currentStatus", "expectedStatus"],
  "properties": {
    "message": {
      "type": "string"
    },
    "currentStatus": {
      "type": "string",
      "enum": [
        "CREATED",
        "ALLOCATED",
        "PENDING",
        "SHIPPED",
        "DELIVERED",
        "CANCELLED",
        "CONFIRMED"
      ]
    },
    "expectedStatus": {
      "type": "string",
      "enum": [
        "CREATED",
        "ALLOCATED",
        "PENDING",
        "SHIPPED",
        "DELIVERED",
        "CANCELLED",
        "CONFIRMED"
      ]
    }
  }
}