{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "minItems": 1,
  "items": {
    "type": "array",
    "required": ["id","name","price"],
    "properties": {
      "id": {"type": "integer"},
      "name": {"type": "string"},
      "price": {"type": "number","minimum": 0}
    }
  }
}