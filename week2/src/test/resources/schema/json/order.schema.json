{
  "$schema": "https://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [
          "id",
          "orderNumber",
          "status",
          "items",
          "subtotal",
          "total"
  ],
  "properties": {
    "id": {
        "type": "integer",
        "minimum": 1
    },
    "orderId": {
      "type": "integer",
      "minimum": 1},
    "orderNumber": {
      "type": "string",
      "minLength": 1},
    "userId": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1}
      ]
    },
    "ownerKey": {
      "type": "string"
    },
      "placedOn": {
        "type": "string",
        "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "ALLOCATED", "SHIPPED", "CANCELLED", "PENDING"]},
    "payment": {
      "type": "string"
    },
    "paymentMethod": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "productId",
          "quantity",
          "product"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "anyOf": [
              { "type": "integer" },
              { "type": "string" }
            ]
          },
          "ownerKey": {
            "type": "string"
          },
          "productId": {
            "type": "integer",
            "minimum": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "fulfilment": {
            "type": "string"
          },
          "product": {
            "type": "object",
            "required": ["id", "name", "category", "price"],
            "properties": {
              "id": {"type": "integer", "minimum": 1},
              "name": {"type": "string", "minLength": 1},
              "category": {"type": "string", "minLength": 1},
              "price": {"type": "integer", "minimum": 0},
              "stock": {"type": "integer", "minimum": 0},
              "brand": {"type": "string"},
              "sku": {"type": "string"},
              "summary": {"type": "string"},
              "tags": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "subtotal": {
      "type": "integer",
      "minimum": 0
    },
    "shipping": {
      "type": "integer",
      "minimum": 0
    },
    "discount": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "deliverySlot": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "coupon": {
      "type": "string"
    }
    ,
    "createdAt": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

