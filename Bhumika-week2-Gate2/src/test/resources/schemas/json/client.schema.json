{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderDetailsSchema",
  "type": "object",
  "required": [
    "id",
    "orderNumber",
    "userId",
    "ownerKey",
    "placedOn",
    "status",
    "payment",
    "paymentMethod",
    "channel",
    "items",
    "subtotal",
    "shipping",
    "discount",
    "total",
    "deliverySlot",
    "address",
    "coupon"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "orderNumber": {
      "type": "string"
    },
    "userId": {
      "type": "integer"
    },
    "ownerKey": {
      "type": "string"
    },
    "placedOn": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string"
    },
    "payment": {
      "type": "string"
    },
    "paymentMethod": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "userId",
          "ownerKey",
          "productId",
          "quantity",
          "size",
          "color",
          "fulfilment",
          "product"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "integer"
          },
          "ownerKey": {
            "type": "string"
          },
          "productId": {
            "type": "integer"
          },
          "quantity": {
            "type": "integer"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "fulfilment": {
            "type": "string"
          },
          "product": {
            "type": "object",
            "required": [
              "id",
              "name",
              "category",
              "price",
              "stock",
              "brand",
              "sku",
              "summary",
              "tags"
            ],
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "price": {
                "type": "integer"
              },
              "stock": {
                "type": "integer"
              },
              "brand": {
                "type": "string"
              },
              "sku": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "subtotal": {
      "type": "integer"
    },
    "shipping": {
      "type": "integer"
    },
    "discount": {
      "type": "integer"
    },
    "total": {
      "type": "integer"
    },
    "deliverySlot": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "coupon": {
      "type": "string"
    }
  }
}