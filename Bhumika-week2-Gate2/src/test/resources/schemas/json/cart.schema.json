{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CartItemSchema",
  "type": "object",

  "required": [
    "id",
    "userId",
    "ownerKey",
    "productId",
    "quantity",
    "size",
    "color",
    "fulfilment",
    "product"
  ],

  "properties": {
    "id": { "type": "integer" },
    "userId": { "type": "integer" },
    "ownerKey": { "type": "string" },
    "productId": { "type": "integer" },
    "quantity": { "type": "integer" },
    "size": { "type": "string" },
    "color": { "type": "string" },
    "fulfilment": { "type": "string" },

    "product": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "price",
        "stock",
        "brand",
        "sku",
        "summary",
        "tags"
      ],

      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "integer" },
        "stock": { "type": "integer" },
        "brand": { "type": "string" },
        "sku": { "type": "string" },
        "summary": { "type": "string" },

        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}