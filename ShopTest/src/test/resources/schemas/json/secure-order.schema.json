{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "orderId", "orderNumber", "status", "payment", "paymentMethod", "channel", "items", "subtotal", "shipping", "discount", "total", "address", "deliverySlot", "userId", "createdAt"
  ],
  "properties": {
    "id": {"type": "integer"},
    "orderId": {"type": "integer"},
    "orderNumber": {"type": "string"},
    "status": {"type": "string"},
    "payment": {"type": "string"},
    "paymentMethod": {"type": "string"},
    "channel": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["product", "quantity", "productId"],
        "properties": {
          "product": {
            "type": "object",
            "required": ["id", "name", "price", "category"],
            "properties": {
              "id": {"type": "integer"},
              "name": {"type": "string"},
              "price": {"type": "number"},
              "category": {"type": "string"}
            }
          },
          "quantity": {
            "type": "integer"
          },
          "productId": {
            "type": "integer"
          }
        }
      }
    },
    "subtotal": {"type": "number"},
    "shipping": {"type": "number"},
    "discount": {"type": "number"},
    "total": {"type": "number"},
    "address": {"type": "string"},
    "deliverySlot": {"type": "string"},
    "userId": {"type": "string"},
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}