{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "token",
    "user"
  ],
  "properties": {
    "token": {
      "type": "string"
    },
    "user": {
      "type": "object",
      "required": [
        "id",
        "email",
        "role",
        "name"
      ],
      "properties": {
        "id": {
          "type": "number"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}