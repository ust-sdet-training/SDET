{
  "$schema": "https://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [
    "items",
    "total"
  ],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "productId",
          "quantity",
          "product"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "integer"
          },
          "ownerKey": {
            "type": "string"
          },
          "productId": {
            "type": "integer",
            "minimum": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "fulfilment": {
            "type": "string"
          },
          "product": {
            "type": "object",
            "required": [
              "id",
              "name",
              "category",
              "price"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 1
              },
              "name": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "price": {
                "type": "integer",
                "minimum": 0
              },
              "stock": {
                "type": "integer",
                "minimum": 0
              },
              "brand": {
                "type": "string"
              },
              "sku": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  }
}