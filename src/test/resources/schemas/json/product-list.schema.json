{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["items","total"],
  "minItems": 1,
  "items": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": ["id","name","price"],
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"},
        "price": {"type": "number","minimum": 0},
        "category": {"type": "string","minLength": 1},
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}