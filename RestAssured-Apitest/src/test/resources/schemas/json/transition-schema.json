{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "type": "object",

  "required": [
    "id",
    "status"
  ],

  "properties": {

    "id": {
      "type": "integer"
    },

    "status": {

      "type": "string",

      "enum": [

        "CREATED",

        "ALLOCATED",

        "SHIPPED"

      ]

    },

    "orderNumber": {
      "type": "string"
    },

    "payment": {
      "type": "string"
    },

    "total": {
      "type": "number"
    }

  }
}