{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["partner", "order"],
  "properties": {
    "partner": {
      "type": "string"
    },
    "order": {
      "type": "object",
      "required": [
        "id",
        "orderNumber",
        "status",
        "payment",
        "paymentMethod",
        "channel",
        "items",
        "subtotal",
        "shipping",
        "discount",
        "total",
        "address",
        "deliverySlot"
      ],
      "properties": {
        "id": {
          "type": "integer"
        },
        "orderNumber": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "payment": {
          "type": "string"
        },
        "paymentMethod": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["productId", "quantity", "product"],
            "properties": {
              "productId": {
                "type": "integer"
              },
              "quantity": {
                "type": "integer",
                "minimum": 1
              },
              "product": {
                "type": "object",
                "required": ["id", "name", "category", "price"],
                "properties": {
                  "id": {
                    "type": "integer"
                  },
                  "name": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "subtotal": {
          "type": "number",
          "minimum": 0
        },
        "shipping": {
          "type": "number",
          "minimum": 0
        },
        "discount": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "address": {
          "type": "string"
        },
        "deliverySlot": {
          "type": "string"
        }
      }
    }
  }
}