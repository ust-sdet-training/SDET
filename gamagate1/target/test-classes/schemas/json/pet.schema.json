{
    "$schema": "https://json-schema.org/draft-04/schema#",
    "type": "object",
    "required":["id","category","name","photoUrls","tags","status"],
    "properties": {
        "id":{"type":"integer","minimum": 1},
        "category":{
            "type": "object",
            "required":["id","name"],
            "properties": {
                "id":{"type":"integer","minimum": 1},
                "name":{"type":"string","minLength":1}
            }
        },
        "name":{"type":"string","minLength":1},
        "photoUrls":{
            "type": "array"
        },
        "tags":{
            "type":"array",
            "properties": {
                "id":{"type":"integer","minimum": 1},
                "name":{"type":"string","minimum": 1}
            }
        },
        "status":{
            "type":"string"
        }
    }

}
